{
  "defaultTargetRoot": "~/.pi/agent",
  "bundleTargetRoot": "~/.agents/skills",
  "cacheRoot": ".cache/upstreams",
  "stateFile": ".agent-stuff-managed.json",
  "bundleStateFile": ".agent-stuff-managed.json",
  "localAssets": [
    {
      "name": "skills",
      "source": "skills",
      "destination": "skills",
      "mode": "children"
    },
    {
      "name": "extensions",
      "source": "extensions",
      "destination": "extensions",
      "mode": "children"
    },
    {
      "name": "themes",
      "source": "themes",
      "destination": "themes",
      "mode": "children"
    },
    {
      "name": "commands",
      "source": "commands",
      "destination": "commands",
      "mode": "children"
    },
    {
      "name": "intercepted-commands",
      "source": "intercepted-commands",
      "destination": "intercepted-commands",
      "mode": "children"
    },
    {
      "name": "plumbing-commands",
      "source": "plumbing-commands",
      "destination": "plumbing-commands",
      "mode": "children"
    }
  ],
  "upstreams": [
    {
      "name": "superpowers",
      "repoUrl": "https://github.com/obra/superpowers.git",
      "ref": "main",
      "cacheSubdir": "superpowers",
      "sourceBase": "skills",
      "bundleName": "superpowers"
    },
    {
      "name": "cloudflare-skills",
      "repoUrl": "https://github.com/cloudflare/skills.git",
      "ref": "main",
      "cacheSubdir": "cloudflare-skills",
      "sourceBase": "skills",
      "bundleName": "cloudflare-skills"
    }
  ]
}
